{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd apps/server && bun run generate && cd ../web/ && bun run build",
    "startCommand": "bun run start --filter=@scottystack/web...",
    "watchPatterns": [
      "/apps/web/**",
      "/packages/common/**",
      "/packages/access-control/**"
    ]
  }
}
